#!/usr/bin/env ruby
# frozen_string_literal: true
#
# linear — Linear issue management CLI (ships in the hgl_linear gem).
#
# A THIN CLI over Linear::Client (the gem library). All Linear GraphQL + lifecycle conventions live in
# Linear::Client; this layer only parses args, prints stdout, and handles local files (git/images).
#
# Multi-team: the workspace may have several teams (AKA / AGT / ORC / …). create/list default to
# $LINEAR_DEFAULT_TEAM (override with --team KEY); every other command takes an issue id (AKA-N,
# AGT-N, …) and resolves its team automatically — no --team needed. Config is env-only:
#   LINEAR_API_KEY       (required)  — get one at linear.app/settings/api
#   LINEAR_DEFAULT_TEAM  (optional)  — default team key for create/list (e.g. AGT, ORC, AKA)
#
# Usage examples:
#   linear search "<keywords>" [--limit N]
#   linear create "Title" [--team KEY] [--label Bug|Feature|...] [--priority urgent|high|medium|low] [--desc "body"] ...
#   linear start AKA-N --session "..."   |   linear review AKA-N --sha <sha>   |   linear close AKA-N

require "net/http"
require "uri"
require "json"

# Soft-load a .env from the working directory when dotenv is available, so `linear` "just works" in a
# project checkout that keeps its key in .env. Falls back to the real environment otherwise (the
# canonical config path on servers / the agent-ops box). Never fatal if dotenv isn't installed.
begin
  require "dotenv"
  Dotenv.load(".env") if File.exist?(".env")
rescue LoadError
  # dotenv not present — read LINEAR_API_KEY / LINEAR_DEFAULT_TEAM straight from ENV.
end

require "hgl_linear"

# This program's invoked name (`linear`, or `bin/linear` via a host shim) — used in usage strings.
PROG = File.basename($PROGRAM_NAME)

# Re-tag command-line args as UTF-8. In this environment Encoding.default_external is US-ASCII, so
# Ruby tags ARGV bytes as US-ASCII/ASCII-8BIT — a title/desc/note/comment containing a non-ASCII char
# (an em-dash, an arrow like ⇄, an accent — all routine in this repo) then crashes the moment it is
# `.strip`ed or joined with the UTF-8 markdown we build (Encoding::CompatibilityError). The shell
# hands us UTF-8 bytes, so re-tagging is correct; `.scrub` keeps even malformed bytes non-fatal. (AKA-218)
ARGV.map! { |a| a.dup.force_encoding("UTF-8").scrub }

# One shared client for the whole invocation (reads LINEAR_API_KEY from ENV; memoizes teams/states).
# The workspace is multi-team (AKA / AGT / ORC / …); the client resolves any team by key.
CLIENT = Linear::Client.new

# Default team for `create`/`list` when no --team is given: $LINEAR_DEFAULT_TEAM if set, else nil so
# the client falls back to its own default (AKA). A per-command --team always wins. Identifier-based
# commands (view/close/comment/start/review/label/…) need no team — they resolve it from the issue id.
def default_team
  t = ENV["LINEAR_DEFAULT_TEAM"].to_s.strip
  t.empty? ? nil : t
end

# UTC timestamp used in the auto-generated comment bodies (session start, merged SHA, reopen).
def ts
  Time.now.utc.strftime("%Y-%m-%dT%H:%MZ")
end

# --- Commit links --------------------------------------------------------------
# Linear renders a clickable GitHub link from any commit we attach. Resolving the ref + subject is a
# local-git concern, so it stays in the CLI; the resulting markdown is posted via CLIENT.comment.

# Run a git command and return its stdout as a UTF-8 string. Ruby tags backtick output with
# Encoding.default_external, which is US-ASCII in this environment — so a commit subject carrying a
# non-ASCII char (e.g. the ⇄ in AKA-207's subject) made the very first `.strip` raise
# Encoding::CompatibilityError, crashing `linear commit` (AKA-218). git emits UTF-8, so re-tag the
# bytes as UTF-8 before any string op; `.scrub` makes even genuinely malformed bytes non-fatal.
def git_capture(cmd)
  `#{cmd}`.force_encoding("UTF-8").scrub
end

# Resolve the repo's GitHub web base (https://github.com/<owner>/<repo>) from the `origin` remote —
# handles both SSH (git@github.com:owner/repo.git) and HTTPS forms. Returns nil if origin isn't GitHub.
def github_web_base
  url = git_capture("git config --get remote.origin.url 2>/dev/null").strip
  return nil if url.empty?

  case url
  when %r{\Agit@github\.com:(.+?)(?:\.git)?\z}       then "https://github.com/#{$1}"
  when %r{\Assh://git@github\.com/(.+?)(?:\.git)?\z} then "https://github.com/#{$1}"
  when %r{\Ahttps://github\.com/(.+?)(?:\.git)?\z}   then "https://github.com/#{$1}"
  end
end

# Reject anything that isn't a plain git ref so the ref is safe to splice into the `git` shell-outs
# below (no command injection from --sha values).
def safe_ref(ref)
  abort "Invalid git ref: #{ref.inspect}" unless ref.to_s =~ %r{\A[A-Za-z0-9_./^~@-]+\z}

  ref
end

# Markdown for a commit reference: a clickable short-SHA link to GitHub + the commit subject.
# Resolves the ref locally (default HEAD) for the full SHA + subject; falls back to a bare/linked ref
# when the object isn't in this checkout or origin != GitHub.
def commit_markdown(ref)
  ref  = safe_ref(ref)
  full = git_capture("git rev-parse --verify --quiet #{ref}^{commit} 2>/dev/null").strip
  base = github_web_base
  if full.empty?
    base ? "[`#{ref}`](#{base}/commit/#{ref})" : "`#{ref}`"
  else
    short   = full[0, 8]
    subject = git_capture("git log -1 --format=%s #{full} 2>/dev/null").strip
    link    = base ? "[`#{short}`](#{base}/commit/#{full})" : "`#{short}`"
    subject.empty? ? link : "#{link} #{subject}"
  end
end

# --- Screenshots ---------------------------------------------------------------
# Linear renders any markdown image whose URL is a Linear asset URL. To get one we ask Linear for a
# signed upload slot (CLIENT.request_file_upload — the GraphQL half), PUT the bytes to the storage
# URL (local-file I/O, here), then embed ![..](assetUrl). Used by create/comment (--image) + attach.

IMAGE_CONTENT_TYPES = {
  ".png" => "image/png", ".jpg" => "image/jpeg", ".jpeg" => "image/jpeg",
  ".gif" => "image/gif", ".webp" => "image/webp"
}.freeze

def content_type_for(path)
  ext = File.extname(path).downcase
  IMAGE_CONTENT_TYPES[ext] ||
    abort("Unsupported image type #{ext.inspect} for #{path} — use png/jpg/jpeg/gif/webp")
end

# Upload a local image to Linear; returns the public assetUrl to embed as markdown.
def upload_image(path)
  abort "Image not found: #{path}" unless File.file?(path)

  bytes        = File.binread(path)
  content_type = content_type_for(path)
  filename     = File.basename(path)

  uf = CLIENT.request_file_upload(content_type: content_type, filename: filename, size: bytes.bytesize)
  abort "Linear refused the upload for #{filename}" unless uf && uf["uploadUrl"]

  # PUT the raw bytes to the signed storage URL. No Authorization header here — the URL is
  # pre-signed; we only echo back the headers Linear hands us plus Content-Type.
  upload_uri = URI(uf["uploadUrl"])
  http = Net::HTTP.new(upload_uri.host, upload_uri.port)
  http.use_ssl = (upload_uri.scheme == "https")
  put = Net::HTTP::Put.new(upload_uri.request_uri)
  put["Content-Type"] = content_type
  (uf["headers"] || []).each { |h| put[h["key"]] = h["value"] }
  put.body = bytes
  res = http.request(put)
  unless res.is_a?(Net::HTTPSuccess)
    abort "Upload PUT failed for #{filename}: HTTP #{res.code} #{res.message}"
  end
  uf["assetUrl"]
end

# Upload each path and return a markdown block of inline images (blank-line separated).
def images_markdown(paths)
  return "" if paths.nil? || paths.empty?

  paths.map { |p| "![#{File.basename(p)}](#{upload_image(p)})" }.join("\n\n")
end

# Join non-empty text fragments with blank lines (for body + screenshot blocks).
def join_md(*parts)
  parts.flatten.reject { |s| s.nil? || s.to_s.strip.empty? }.join("\n\n")
end

# Human-readable parent / sub-issue / relation lines for an issue node returned by
# CLIENT.find_issue (carries parent/children/relations/inverseRelations). Pure formatting.
def format_issue_links(issue)
  out = []
  if (par = issue.dig("parent", "identifier"))
    out << "parent (epic): #{par}"
  end
  kids = issue.dig("children", "nodes")&.map { |c| c["identifier"] } || []
  out << "sub-issues:    #{kids.join(", ")}" if kids.any?
  (issue.dig("relations", "nodes") || []).each do |r|
    verb = { "blocks" => "blocks", "duplicate" => "duplicate of", "similar" => "similar to" }[r["type"]] || "related to"
    out << "#{verb} #{r.dig("relatedIssue", "identifier")}"
  end
  (issue.dig("inverseRelations", "nodes") || []).each do |r|
    verb = { "blocks" => "blocked by", "duplicate" => "duplicated by", "similar" => "similar to" }[r["type"]] || "related to"
    out << "#{verb} #{r.dig("issue", "identifier")}"
  end
  out
end

def cmd_create(args)
  title = args.shift or abort "Usage: #{PROG} create \"Title\" [--team KEY] [--label X] [--priority X] [--desc \"body\"] [--image PATH ...] [--parent AKA-N] [--blocked-by AKA-N] [--blocks AKA-N] [--related AKA-N]"
  label_name, priority_name, description = nil, "medium", nil
  images = []
  parent_ref = nil
  blocks_refs, blocked_by_refs, related_refs = [], [], []
  team_key = default_team   # --team KEY > $LINEAR_DEFAULT_TEAM > AKA (the client's fallback)

  i = 0
  while i < args.length
    case args[i]
    when "--team"                   then team_key      = args[i + 1]; i += 2
    when "--label"                  then label_name    = args[i + 1]; i += 2
    when "--priority"               then priority_name = args[i + 1]; i += 2
    when "--desc", "--description"  then description   = args[i + 1]; i += 2
    when "--image"                  then images       << args[i + 1]; i += 2
    when "--parent"                 then parent_ref     = args[i + 1]; i += 2
    when "--blocks"                 then blocks_refs   << args[i + 1]; i += 2
    when "--blocked-by", "--depends-on", "--after" then blocked_by_refs << args[i + 1]; i += 2
    when "--related", "--relates-to"               then related_refs    << args[i + 1]; i += 2
    else i += 1
    end
  end

  # Always attach screenshots when given — uploaded and embedded under a Screenshots heading. (Image
  # upload is a local-file concern, so the CLI builds the final description, then hands it to the client.)
  if images.any?
    description = join_md(description, "**Screenshots**", images_markdown(images))
  end

  result = CLIENT.create(
    title: title, label: label_name, priority: priority_name, description: description, team: team_key,
    parent: parent_ref, blocks: blocks_refs, blocked_by: blocked_by_refs, related: related_refs
  )
  issue = result[:issue]
  puts "#{issue["identifier"]}: #{issue["title"]}"
  puts issue["url"]

  # --- Dependency links — applied AT create time so they're never forgotten ----
  result[:links].each do |lk|
    verb = { "parent" => "↳ sub-issue of", "blocks" => "↳ blocks",
             "blocked_by" => "↳ blocked by", "related" => "↳ related to" }[lk[:kind]]
    if lk[:ok]
      puts "  #{verb} #{lk[:identifier]}"
    else
      warn "  ! could not link #{lk[:kind].tr("_", " ")} #{lk[:ref]}"
    end
  end
end

def cmd_view(args)
  identifier = args.shift or abort "Usage: #{PROG} view AKA-N"
  issue = CLIENT.find_issue(identifier)
  abort "Issue #{identifier} not found" unless issue

  puts "#{issue["identifier"]}: #{issue["title"]}"
  puts "  State:    #{issue.dig("state", "name")}"
  puts "  Priority: #{CLIENT.priority_label(issue["priority"])}"
  puts "  Assignee: #{issue.dig("assignee", "name") || "unassigned"}"
  puts "  Labels:   #{issue.dig("labels", "nodes")&.map { |l| l["name"] }&.join(", ") || "none"}"
  puts "  URL:      #{issue["url"]}"
  links = format_issue_links(issue)
  unless links.empty?
    puts "  Links:    #{links.first}"
    links.drop(1).each { |l| puts "            #{l}" }
  end
  puts  ""
  puts issue["description"] if issue["description"] && !issue["description"].empty?
end

def cmd_url(args)
  identifier = args.shift or abort "Usage: #{PROG} url AKA-N"
  issue = CLIENT.find_issue(identifier) or abort "Issue #{identifier} not found"
  puts issue["url"]
end

def cmd_retitle(args)
  identifier = args.shift or abort "Usage: #{PROG} retitle AKA-N \"New title\""
  new_title  = args.shift or abort "Usage: #{PROG} retitle AKA-N \"New title\""
  res = CLIENT.retitle(identifier, new_title)
  updated = res[:issue]
  puts "#{updated["identifier"]}: \"#{res[:old_title]}\" → \"#{updated["title"]}\""
  puts updated["url"]
end

def cmd_close(args)
  identifier = args.shift or abort "Usage: #{PROG} close AKA-N [--comment \"reason\"]"
  comment = nil
  i = 0
  while i < args.length
    case args[i]
    when "--comment" then comment = args[i + 1]; i += 2
    else i += 1
    end
  end

  res = CLIENT.transition(identifier, :done, comment: comment)
  updated = res[:issue]
  puts "Closed #{updated["identifier"]}: #{updated["title"]} → #{updated.dig("state", "name")}"
  puts updated["url"]
  puts "Comment added." if comment
end

def cmd_list(args)
  status_filter = nil
  label_filter  = nil
  team_key      = default_team
  i = 0
  while i < args.length
    case args[i]
    when "--status" then status_filter = args[i + 1]; i += 2
    when "--label"  then label_filter  = args[i + 1]; i += 2
    when "--team"   then team_key      = args[i + 1]; i += 2
    else i += 1
    end
  end

  issues = CLIENT.list(status: status_filter, label: label_filter, team: team_key)
  if issues.empty?
    puts "No issues found."
    return
  end

  issues.each do |issue|
    pri       = CLIENT.priority_label(issue["priority"])
    label_str = issue.dig("labels", "nodes")&.map { |l| l["name"] }&.join(",")
    label_str = label_str && !label_str.empty? ? " [#{label_str}]" : ""
    puts "#{issue["identifier"].ljust(8)} #{issue.dig("state", "name").ljust(12)} #{pri.ljust(8)} #{issue["title"]}#{label_str}"
  end
end

def cmd_comment(args)
  identifier = args.shift or abort "Usage: #{PROG} comment AKA-N \"body\" [--image PATH ...]"
  body = args.shift or abort "Usage: #{PROG} comment AKA-N \"body\" [--image PATH ...]"
  images = []
  i = 0
  while i < args.length
    case args[i]
    when "--image" then images << args[i + 1]; i += 2
    else i += 1
    end
  end
  body = join_md(body, images_markdown(images)) if images.any?
  CLIENT.comment(identifier, body)
  puts "Comment added to #{identifier}."
end

# Attach screenshots (repro / QA evidence) to an issue as a comment with inline images.
# Positional args after AKA-N are image paths; --note adds a caption above them.
def cmd_attach(args)
  identifier = args.shift or abort "Usage: #{PROG} attach AKA-N PATH [PATH ...] [--note \"caption\"]"
  note  = nil
  paths = []
  i = 0
  while i < args.length
    case args[i]
    when "--note" then note = args[i + 1]; i += 2
    else paths << args[i]; i += 1
    end
  end
  abort "Usage: #{PROG} attach AKA-N PATH [PATH ...] [--note \"caption\"]" if paths.empty?
  body = join_md(note, images_markdown(paths))
  CLIENT.comment(identifier, body)
  puts "Attached #{paths.length} image(s) to #{identifier}."
end

def cmd_start(args)
  identifier = args.shift or abort "Usage: #{PROG} start AKA-N [--session \"name\"]"
  session_name = nil
  i = 0
  while i < args.length
    case args[i]
    when "--session" then session_name = args[i + 1]; i += 2
    else i += 1
    end
  end

  body = session_name && "Session started: #{session_name} | Agent: Claude | #{ts}"
  res  = CLIENT.transition(identifier, :in_progress, comment: body)
  puts "#{identifier} → #{res[:issue].dig("state", "name")}"
  puts "Comment: #{body}" if body
end

def cmd_review(args)
  identifier = args.shift or abort "Usage: #{PROG} review AKA-N [--sha <sha>]"
  sha = nil
  i = 0
  while i < args.length
    case args[i]
    when "--sha" then sha = args[i + 1]; i += 2
    else i += 1
    end
  end

  body = sha && "Merged to main: #{commit_markdown(sha)} | #{ts} — Hatchbox deploy in progress"
  res  = CLIENT.transition(identifier, :in_review, comment: body)
  puts "#{identifier} → #{res[:issue].dig("state", "name")}"
  puts "Comment: #{body}" if body
end

# Attach a commit to an issue as a comment with a clickable GitHub link + subject. Defaults to HEAD —
# run it after every `git commit` tied to the issue so the ticket carries a linked trail of each
# commit (not just the final merge SHA). Does NOT change state. --note adds a caption line above.
def cmd_commit(args)
  identifier = args.shift or abort "Usage: #{PROG} commit AKA-N [--sha <ref>] [--note \"context\"]"
  ref  = "HEAD"
  note = nil
  i = 0
  while i < args.length
    case args[i]
    when "--sha"  then ref  = args[i + 1]; i += 2
    when "--note" then note = args[i + 1]; i += 2
    else i += 1
    end
  end

  md   = commit_markdown(ref)
  body = join_md(note, "Commit: #{md} | #{ts}")
  CLIENT.comment(identifier, body)
  puts "#{identifier}: commit linked — #{md}"
end

def cmd_label(args)
  identifier = args.shift or abort "Usage: #{PROG} label AKA-N <label>"
  label_name = args.shift or abort "Usage: #{PROG} label AKA-N <label>"
  CLIENT.add_labels(identifier, [label_name])
  puts "#{identifier}: label '#{label_name}' applied."
end

def cmd_cancel(args)
  identifier = args.shift or abort "Usage: #{PROG} cancel AKA-N [--comment \"reason\"]"
  comment = nil
  i = 0
  while i < args.length
    case args[i]
    when "--comment" then comment = args[i + 1]; i += 2
    else i += 1
    end
  end

  res = CLIENT.transition(identifier, :canceled, comment: comment)
  updated = res[:issue]
  puts "Canceled #{updated["identifier"]} → #{updated.dig("state", "name")}"
end

# Full-text dedup search — relevance-ranked across title + description, ALL states (Done/Canceled
# included) so reopen/link candidates surface. Run this BEFORE `create` to avoid filing a duplicate.
def cmd_search(args)
  term  = args.shift or abort "Usage: #{PROG} search \"<keywords>\" [--limit N]"
  limit = 10
  i = 0
  while i < args.length
    case args[i]
    when "--limit" then limit = (args[i + 1] || "10").to_i; i += 2
    else i += 1
    end
  end

  issues = CLIENT.search(term, limit: limit)
  if issues.empty?
    puts "No candidates for #{term.inspect} — safe to create a new one."
    return
  end

  # searchIssues is fuzzy/relevance-ranked — it returns loose matches even for unrelated terms, so
  # these are CANDIDATES to judge, not confirmed dups. Only act on a TRUE match.
  puts "#{issues.length} candidate(s) for #{term.inspect} (relevance-ranked — judge before creating):"
  puts "  ↳ true match? reopen a Done/Canceled one (⟲), or relate/cancel-as-duplicate an open one — don't create a dup."
  puts
  issues.each do |issue|
    pri       = CLIENT.priority_label(issue["priority"])
    label_str = issue.dig("labels", "nodes")&.map { |l| l["name"] }&.join(",")
    label_str = label_str && !label_str.empty? ? " [#{label_str}]" : ""
    # Flag the states that are reopen candidates so a skimming agent/human notices.
    state     = issue.dig("state", "name")
    flag      = %w[completed canceled].include?(issue.dig("state", "type")) ? " ⟲" : ""
    puts "#{issue["identifier"].ljust(8)} #{(state + flag).ljust(14)} #{pri.ljust(8)} #{issue["title"]}#{label_str}"
    puts "         #{issue["url"]}"
  end
end

# Move a Done/Canceled (or any) issue back to Todo/In Progress — for a recurrence of already-closed
# work. Keeps the original repro, history, and merged-SHA trail. Defaults to Todo; --in-progress
# reopens straight to active.
def cmd_reopen(args)
  identifier = args.shift or abort "Usage: #{PROG} reopen AKA-N [--in-progress] [--comment \"why it recurred\"]"
  to_progress = false
  comment     = nil
  i = 0
  while i < args.length
    case args[i]
    when "--in-progress", "--in_progress" then to_progress = true; i += 1
    when "--comment"                      then comment = args[i + 1]; i += 2
    else i += 1
    end
  end

  body = comment || "Reopened — recurrence of previously-closed work. #{ts}"
  res  = CLIENT.reopen(identifier, to_progress: to_progress, comment: body)
  puts "#{identifier}: #{res[:from]} → #{res[:to]} (reopened)"
  puts "Comment: #{body}"
end

# Create a real Linear relation between two issues (shows in the UI, unlike a text "duplicate of
# AKA-X" comment). --type related (default), blocks, blocked-by, duplicate, or similar. For an
# epic→sub-ticket breakdown use the `parent` command instead.
def cmd_relate(args)
  a = args.shift or abort "Usage: #{PROG} relate AKA-N AKA-M [--type related|blocks|blocked-by|duplicate|similar]"
  b = args.shift or abort "Usage: #{PROG} relate AKA-N AKA-M [--type related|blocks|blocked-by|duplicate|similar]"
  type = "related"
  i = 0
  while i < args.length
    case args[i]
    when "--type" then type = (args[i + 1] || "related").downcase; i += 2
    else i += 1
    end
  end

  res = CLIENT.relate(a, b, type: type)
  if res[:type] == "blocked-by"
    puts "#{a} blocked by #{b}."
  else
    verb = case res[:type]
           when "duplicate" then "marked as duplicate of"
           when "blocks"    then "blocks"
           when "similar"   then "marked similar to"
           else "related to"
           end
    puts "#{a} #{verb} #{b}."
  end
end

# Make AKA-CHILD a sub-issue of AKA-PARENT — Linear's native epic hierarchy, the right model for an
# epic broken into numbered sub-tickets (e.g. "Radar 1/6..6/6"). Unlike `relate`, this shows as a
# real parent/sub-issue with progress rollup.
def cmd_parent(args)
  child  = args.shift or abort "Usage: #{PROG} parent AKA-CHILD AKA-PARENT"
  parent = args.shift or abort "Usage: #{PROG} parent AKA-CHILD AKA-PARENT"
  CLIENT.set_parent_by_identifier(child, parent)
  puts "#{child} is now a sub-issue of #{parent}."
end

# Remove any relation(s) between two issues (the inverse of `relate`) — e.g. to clean up a link
# created in error. Deletes in both directions if present.
def cmd_unrelate(args)
  a = args.shift or abort "Usage: #{PROG} unrelate AKA-N AKA-M"
  b = args.shift or abort "Usage: #{PROG} unrelate AKA-N AKA-M"
  count = CLIENT.unrelate(a, b)
  abort "No relation between #{a} and #{b}." if count.zero?

  puts "Removed #{count} relation(s) between #{a} and #{b}."
end

begin
  command = ARGV.shift
  case command
  when "create"  then cmd_create(ARGV)
  when "view"    then cmd_view(ARGV)
  when "url"     then cmd_url(ARGV)
  when "retitle", "rename" then cmd_retitle(ARGV)
  when "close"   then cmd_close(ARGV)
  when "cancel"  then cmd_cancel(ARGV)
  when "list"    then cmd_list(ARGV)
  when "search"  then cmd_search(ARGV)
  when "reopen"  then cmd_reopen(ARGV)
  when "parent"  then cmd_parent(ARGV)
  when "relate"  then cmd_relate(ARGV)
  when "unrelate" then cmd_unrelate(ARGV)
  when "comment" then cmd_comment(ARGV)
  when "attach"  then cmd_attach(ARGV)
  when "commit"  then cmd_commit(ARGV)
  when "start"   then cmd_start(ARGV)
  when "review"  then cmd_review(ARGV)
  when "label"   then cmd_label(ARGV)
  else
    puts <<~USAGE
      #{PROG} — Linear issue CLI (hgl_linear gem; default team #{default_team || Linear::Client::DEFAULT_TEAM_KEY})

      Multi-team: the workspace has several teams (AKA / AGT / ORC / …). create/list default to
      #{default_team || Linear::Client::DEFAULT_TEAM_KEY} (override with --team KEY, or set $LINEAR_DEFAULT_TEAM). Every other command takes an
      issue id (AKA-N, AGT-N, …) and resolves its team automatically — no --team needed.

      Commands:
        create  "Title" [--team KEY] [--label Bug|Feature|Infrastructure|Ops] [--priority urgent|high|medium|low] [--desc "body"] [--image PATH ...]
                [--parent AKA-N] [--blocked-by AKA-N] [--blocks AKA-N] [--related AKA-N]   ← link deps AT create time
        search  "<keywords>" [--limit N]             full-text dedup search (ALL states; run BEFORE create)
        list    [--status todo|in_progress|done] [--label Bug] [--team KEY]
        view    AKA-N                                shows parent/sub-issues/relations under "Links:"
        url     AKA-N
        retitle AKA-N "New title"                     change an issue's title (alias: rename); prints old → new
        reopen  AKA-N [--in-progress] [--comment "why"]   move a Done/Canceled issue back (recurrence)
        parent  AKA-CHILD AKA-PARENT                  make CHILD a sub-issue of an epic (native hierarchy + rollup)
        relate  AKA-N AKA-M [--type related|blocks|blocked-by|duplicate|similar]   link two issues (real Linear relation)
        unrelate AKA-N AKA-M                          remove the relation(s) between two issues (inverse of relate)
        start   AKA-N [--session "session name"]     move to In Progress + log session attribution
        review  AKA-N [--sha <sha>]                  move to In Review + log merged SHA as a GitHub link
        commit  AKA-N [--sha <ref>] [--note "..."]   link a commit (clickable GitHub link + subject; default HEAD)
        comment AKA-N "body" [--image PATH ...]      add a comment (QA result, notes, etc.)
        attach  AKA-N PATH [PATH ...] [--note "..."]  attach screenshot(s) — repro/QA evidence
        label   AKA-N <label>                         add a label (auto-creates it if missing)
        close   AKA-N [--comment "reason"]           mark Done (verified on prod)
        cancel  AKA-N [--comment "reason"]           mark Canceled (duplicates / won't-do)

      Labels auto-create on first use, so --label Bug works even before the label exists.

      Dependencies (link them AT create time so they're never forgotten):
        --parent AKA-N      sub-issue of an epic (epic breakdown — use this for "X 1/6..6/6")
        --blocked-by AKA-N  this ticket depends on AKA-N (can't ship until AKA-N does)
        --blocks AKA-N      this ticket must ship before AKA-N
        --related AKA-N     sibling / same-root-cause follow-up (no hard ordering)

      Lifecycle:
        search (dedup) → create [+link deps] → start (picked up) → commit (after each commit) → review --sha (merged to main) → comment (QA) → close (prod verified)
        └─ link every commit tied to the issue with `commit AKA-N` so the ticket carries a clickable GitHub trail.
        └─ on a match: `reopen` a Done/Canceled one, or `relate`/`cancel --type duplicate` instead of creating a dup.

      Config is env-only: LINEAR_API_KEY (required) + LINEAR_DEFAULT_TEAM (default create/list team).
      A .env in the working directory is auto-loaded when the `dotenv` gem is available.

      Requires LINEAR_API_KEY — get one at linear.app/settings/api
    USAGE
  end
rescue Linear::Client::UsageLimited => e
  # Terminal plan/usage limit (e.g. the free-plan active-issue cap). Surface Linear's own upgrade copy.
  warn "Linear error: #{e.message}"
  warn "  ↳ This workspace hit a Linear plan limit. Upgrade at linear.app/settings/billing or contact sales@linear.app, then retry."
  exit 1
rescue Linear::Client::RateLimited => e
  # The client already backed off + retried (MAX_ATTEMPTS) before giving up.
  warn "Linear error: #{e.message}"
  warn "  ↳ Linear is rate-limiting requests; the client already retried with backoff. Wait a moment and run it again."
  exit 1
rescue Linear::Client::Error => e
  # Typed errors from the shared client surface as a clean CLI failure (the client never exits/aborts).
  warn "Linear error: #{e.message}"
  exit 1
end
